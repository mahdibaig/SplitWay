// Splitway build-time secrets — template. Copy to `Secrets.xcconfig`
// (which is gitignored) and fill in your own values from your deployed
// assistant proxy (see proxy/README.md).
//
// The `$()` between `https:` and `//` is the standard xcconfig escape for
// the `//` comment marker. Don't remove it.

SPLITWAY_ASSISTANT_BASE_URL = https:/$()/splitway-assistant.<your-account>.workers.dev
SPLITWAY_ASSISTANT_SHARED_SECRET = <paste the long random string you set with `wrangler secret put APP_SHARED_SECRET`>
